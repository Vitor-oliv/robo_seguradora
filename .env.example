# Exemplo de arquivo .env para configuração via variáveis de ambiente
# Copie este arquivo para .env e preencha com suas credenciais reais

# Credenciais da Seguradora
SEGURADORA_LOGIN=seu_usuario_aqui
SEGURADORA_SENHA=sua_senha_aqui

# API de Estoque
ESTOQUE_API_URL=https://api.seuestoque.com.br/v1
ESTOQUE_API_KEY=sua_api_key_aqui
